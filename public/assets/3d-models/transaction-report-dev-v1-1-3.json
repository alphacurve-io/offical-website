    {
      "parameters": {
        "language": "pythonNative",
        "pythonCode": "\noutput_items = []\nfor index, item in enumerate(_items):\n  if \"binary\" in item:\n    for key, binary_data in item[\"binary\"].items():\n      file_content = \"\"\n      file_name = binary_data.get(\"fileName\", f\"file_{index}\")\n      \n      try:\n        # n8n 的 binary_data 本身就包含文件內容\n        # 直接從 'data' 欄位讀取\n        if isinstance(binary_data.get(\"data\"), bytes):\n          file_bytes = binary_data[\"data\"]\n        else:\n          # 如果是 buffer 或其他格式\n          file_bytes = bytes(binary_data[\"data\"])\n        \n        # 嘗試解碼為文字\n        file_content = file_bytes.decode('utf-8', errors='ignore')\n        \n      except Exception as e:\n        file_content = f\"Error: {str(e)}\"\n      \n      output_items.append({\n        \"json\": {\n          \"file_index\": index,\n          \"file_name\": file_name,\n          \"file_size\": binary_data.get(\"fileSize\", 0),\n          \"file_content\": file_content[:5000],  # 只取前 5000 字元\n          \"mime_type\": binary_data.get(\"mimeType\", \"\")\n        },\n        \"binary\": {\n          \"data\": binary_data\n        }\n      })\n\nreturn {'json': {'chatInput': output_items}}"
      },

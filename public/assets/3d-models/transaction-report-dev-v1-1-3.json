    {
      "parameters": {
        "jsCode": "// Loop over input items and add a new field called 'my_new_field' to the JSON of each one\nconst result = {};\nconst report = {};\nconst transaction_collection = {};\n\nresult.chatInput = {};\nreport.statistics = {};\nreport.statistics.files = [];\nreport.transactions = {};\nreport.transactions.files = [];\nreport.withdrawal = {};\nreport.withdrawal.files = [];\n\nlet total_profit = 0;\nlet total_taxes = 0;\nlet total_commission = 0;\nlet total_swap = 0;\n\n/**\n * 分析並合併所有帳戶的 withdrawal_list\n */\nfunction analyze_withdrawal_list(items) {\n  // 使用普通 object 來累積同一年的提款數據\n  const yearly_withdrawals = {};\n  \n  // 遍歷每個帳戶\n  for (const item of items) {\n    // 從 item.json 中取得數據\n    const json_data = item.json || {};\n    \n    if (!json_data.success) {\n      continue;\n    }\n    \n    // 取得帳戶編號\n    const account = json_data.account || '';\n    const withdrawal_list = json_data.withdrawal_list || [];\n    \n    // 遍歷每個提款記錄\n    for (const withdrawal of withdrawal_list) {\n      const open_year = withdrawal.open_year;\n      if (!open_year) {\n        continue;\n      }\n      \n      // 如果這一年還沒有記錄,初始化\n      if (!yearly_withdrawals[open_year]) {\n        yearly_withdrawals[open_year] = {\n          total: 0,\n          notes: []\n        };\n      }\n      \n      // 累加 total\n      yearly_withdrawals[open_year].total += withdrawal.total || 0;\n      \n      // 收集 notes,加入 account 前綴\n      const note = withdrawal.note || '';\n      if (note) {\n        // 格式: account:note\n        const account_note = `${account}:${note}`;\n        if (!yearly_withdrawals[open_year].notes.includes(account_note)) {\n          yearly_withdrawals[open_year].notes.push(account_note);\n        }\n      }\n    }\n  }\n  \n  // 轉換為最終格式\n  const merged_list = [];\n  for (const [open_year, data] of Object.entries(yearly_withdrawals)) {\n    // 合併 notes\n    const combined_note = data.notes.length > 0 ? data.notes.join(', ') : '';\n    \n    merged_list.push({\n      open_year: open_year,\n      total: data.total,\n      note: combined_note\n    });\n  }\n  \n  // 按年份排序\n  merged_list.sort((a, b) => a.open_year - b.open_year);\n  \n  return merged_list;\n}\n\n/**\n * 分析並合併所有帳戶的 transaction_flow\n */\nfunction analyze_transaction_flows(items) {\n  // 使用普通 object 來累積同一天的交易數據\n  const daily_transactions = {};\n  \n  // 遍歷每個帳戶\n  for (const item of items) {\n    // 從 item.json 中取得數據\n    const json_data = item.json || {};\n    \n    if (!json_data.success) {\n      continue;\n    }\n    \n    // 取得帳戶編號\n    const account = json_data.account || '';\n    const transaction_flow = json_data.transaction_flow || [];\n    \n    // 遍歷每個交易流程記錄\n    for (const transaction of transaction_flow) {\n      const open_day = transaction.open_day;\n      if (!open_day) {\n        continue;\n      }\n      \n      // 如果這一天還沒有記錄,初始化\n      if (!daily_transactions[open_day]) {\n        daily_transactions[open_day] = {\n          total_tranin: 0,\n          total_tranout: 0,\n          notes: []\n        };\n      }\n      \n      // 累加 tranin 和 tranout\n      daily_transactions[open_day].total_tranin += transaction.total_tranin || 0;\n      daily_transactions[open_day].total_tranout += transaction.total_tranout || 0;\n      \n      // 收集 notes,加入 account 前綴\n      const note = transaction.note || '';\n      if (note) {\n        // 格式: account:note\n        const account_note = `${account}:${note}`;\n        if (!daily_transactions[open_day].notes.includes(account_note)) {\n          daily_transactions[open_day].notes.push(account_note);\n        }\n      }\n    }\n  }\n  \n  // 轉換為最終格式\n  const merged_flow = [];\n  for (const [open_day, data] of Object.entries(daily_transactions)) {\n    // 合併 notes\n    const combined_note = data.notes.length > 0 ? data.notes.join(', ') : '';\n    \n    // 判斷 match: tranin 和 tranout 的絕對值是否相等\n    const tranin = data.total_tranin;\n    const tranout = data.total_tranout;\n    const match = Math.abs(tranin + tranout) < 0.01; // 使用小誤差來處理浮點數比較\n    \n    merged_flow.push({\n      open_day: open_day,\n      total_tranin: tranin,\n      total_tranout: tranout,\n      match: match,\n      note: combined_note\n    });\n  }\n  \n  // 按日期排序\n  merged_flow.sort((a, b) => a.open_day.localeCompare(b.open_day));\n  \n  return merged_flow;\n}\n\n// 處理主要邏輯\n// 確保 items[0].json.files 存在且是陣列\nconst files = items[0]?.json?.files;\nif (!files || !Array.isArray(files)) {\n  throw new Error('items[0].json.files is not an array or does not exist');\n}\n\nfor (const item of files) {\n  item.json.my_new_field = 1;\n\n  total_profit += item.json.summary.total_profit;\n  total_commission += item.json.summary.total_commission;\n  total_taxes += item.json.summary.total_taxes;\n  total_swap += item.json.summary.total_swap;\n  \n  report.statistics.files.push({\n    success: item.json.success,\n    filename: item.json.filename,\n    account: item.json.account,\n    name: item.json.name,\n    summary: {\n      total_trades: item.json.summary.total_trades,\n      total_profit: item.json.summary.total_profit,\n      total_commission: item.json.summary.total_commission,\n      total_taxes: item.json.summary.total_taxes,\n      total_swap: item.json.summary.total_swap\n    },\n    buy_trades: item.json.buy_trades,\n    sell_trades: item.json.sell_trades,\n    pdf_summary: item.json.pdf_summary\n  });\n  \n  report.transactions.files.push({\n    success: item.json.success,\n    filename: item.json.filename,\n    account: item.json.account,\n    name: item.json.name,\n    list: item.json.transaction_flow\n  });\n  \n  report.withdrawal.files.push({\n    success: item.json.success,\n    filename: item.json.filename,\n    account: item.json.account,\n    name: item.json.name,\n    list: item.json.withdrawal_list\n  });\n}\n\nreport.statistics.all_files_summary = {\n  total_commission: total_commission,\n  total_profit: total_profit,\n  total_swap: total_swap,\n  total_taxes: total_taxes\n};\n\nreport.transactions.record = analyze_transaction_flows(files);\nreport.withdrawal.record = analyze_withdrawal_list(files);\nresult.chatInput = report;\n\nreturn result;"
      },

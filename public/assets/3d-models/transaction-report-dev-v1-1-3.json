      "parameters": {
        "jsCode": "// 為每個 binary 文件創建獨立的 item\nconst outputItems = [];\n\nfor (let index = 0; index < items.length; index++) {\n  const item = items[index];\n  \n  if (item.binary) {\n    // 遍歷所有 binary 文件\n    for (const [key, binaryData] of Object.entries(item.binary)) {\n      outputItems.push({\n        json: {\n          file_index: index,\n          original_key: key,\n          file_name: binaryData.fileName || `file_${index}`,\n          file_size: binaryData.fileSize || 0\n        },\n        binary: {\n          data: binaryData  // 統一使用 \"data\" 作為 binary key\n        }\n      });\n    }\n  }\n}\n\nreturn outputItems;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [

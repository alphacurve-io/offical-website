    {
      "parameters": {
        "jsCode": "// Initialize variables to store results\nlet statistical_results = null;\nlet transaction_flow_report = null;\nlet withdrawal_list = null;\n\n// Loop through items to find the required fields\nfor (const item of items) {\n    const json_data = item.json || {};\n    \n    if (json_data.statistical_results) {\n        statistical_results = json_data.statistical_results;\n    }\n    \n    if (json_data.transaction_flow_report) {\n        transaction_flow_report = json_data.transaction_flow_report;\n    }\n    \n    if (json_data.withdrawal_list) {\n        withdrawal_list = json_data.withdrawal_list;\n    }\n}\n\n// Build the final result\nconst result_parts = [];\n\nif (statistical_results) {\n    result_parts.push(statistical_results);\n}\n\nif (transaction_flow_report) {\n    result_parts.push(\"<hr><hr><p>Transaction Flow</p>\");\n    result_parts.push(transaction_flow_report);\n}\n\nif (withdrawal_list) {\n    result_parts.push(\"<hr><hr><p>Withdrawal List</p>\");\n    result_parts.push(withdrawal_list);\n}\n\n// Return as array of dictionaries\nconst combined_html = result_parts.length > 0 ? result_parts.join(\"\") : \"\";\nreturn [{ json: { combined_report: combined_html } }];"
      },
